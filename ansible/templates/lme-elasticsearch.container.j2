# lme-elasticsearch.container (generated by Ansible)
[Unit]
Description=Elasticsearch Container Service
Requires=lme-network.service lme-setup-certs.service
After=lme-network.service lme-setup-certs.service
PartOf=lme.service

[Service]
Restart=always
Environment=ANSIBLE_VAULT_PASSWORD_FILE=/etc/lme/pass.sh
TimeoutStartSec=5400

[Install]
WantedBy=default.target lme.service

[Container]
ContainerName=lme-elasticsearch

# Base node/cluster settings
{#
  Backward compatibility:
  - Historically LME set node.name=lme-elasticsearch for single-node/local installs.
  - Our tests expect that value.
  - For remote/cluster, allow per-host node names via es_node_name (or default to inventory_hostname).
#}
{% if es_node_name is defined %}
Environment=node.name={{ es_node_name }}
{% elif inventory_hostname in ['localhost', '127.0.0.1'] %}
Environment=node.name=lme-elasticsearch
{% else %}
Environment=node.name={{ inventory_hostname }}
{% endif %}
Environment=cluster.name={{ es_cluster_name | default('LME') }}
Environment=bootstrap.memory_lock=true

{% if es_discovery_type | default('single-node') == 'single-node' %}
# Standalone mode
Environment=discovery.type=single-node
{% else %}
# Cluster mode
Environment=discovery.seed_hosts={{ es_seed_hosts | default([]) | join(',') }}
{% if es_is_initial_master | default(false) %}
Environment=cluster.initial_master_nodes={{ es_initial_masters | default([]) | join(',') }}
{% endif %}
{% endif %}

# Security/TLS settings
Environment=xpack.security.enabled=true
Environment=xpack.security.http.ssl.enabled=true
Environment=xpack.security.http.ssl.key=certs/elasticsearch/elasticsearch.key
Environment=xpack.security.http.ssl.certificate=certs/elasticsearch/elasticsearch.chain.pem
Environment=xpack.security.http.ssl.certificate_authorities=certs/ca/ca.crt
Environment=xpack.security.http.ssl.verification_mode=certificate
Environment=xpack.security.http.ssl.client_authentication=optional
Environment=xpack.security.transport.ssl.enabled=true
Environment=xpack.security.transport.ssl.key=certs/elasticsearch/elasticsearch.key
Environment=xpack.security.transport.ssl.certificate=certs/elasticsearch/elasticsearch.crt
Environment=xpack.security.transport.ssl.certificate_authorities=certs/ca/ca.crt
Environment=xpack.security.transport.ssl.verification_mode=certificate
Environment=xpack.security.transport.ssl.client_authentication=optional
Environment=xpack.license.self_generated.type=basic
Environment=xpack.security.autoconfiguration.enabled=false

Environment=ES_JAVA_OPTS="-Des.entitlements.enabled=false"

Secret=elastic,type=env,target=ELASTIC_PASSWORD
Secret=kibana_system,type=env,target=ELASTICSEARCH_PASSWORD
Secret=kibana_system,type=env,target=KIBANA_PASSWORD

EnvironmentFile=/opt/lme/lme-environment.env
Image=localhost/elasticsearch:LME_LATEST
Network=lme
PodmanArgs= --network-alias lme-elasticsearch --health-interval=2s
PublishPort={{ es_http_publish_port | default('9200:9200') }}
Ulimit=memlock=-1:-1

Volume=lme_certs:/usr/share/elasticsearch/config/certs
Volume=lme_esdata01:/usr/share/elasticsearch/data
Volume=lme_backups:/usr/share/elasticsearch/backups
Volume=/opt/lme/config/elasticsearch.yml:/usr/share/elasticsearch/config/elasticsearch.yml:ro

Notify=healthy
HealthCmd=CMD-SHELL curl -s --cacert config/certs/ca/ca.crt https://localhost:9200 | grep -q 'missing authentication credentials'

User=elasticsearch
UserNS=auto:uidmapping=0:165536:3048,gidmapping=0:165536:3048
#UserNS=auto
