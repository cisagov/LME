# Generated by Ansible (certs role)
# Add host IP address / domain names as needed.

{#
  We generate ONE certificate per logical service name (elasticsearch, kibana, etc.)
  and include all relevant hostnames/IPs as SANs.

  NOTE: The setup script expects these instance names:
  - elasticsearch -> certs/elasticsearch/elasticsearch.(crt|key|chain.pem)
#}

{% set es_hosts = groups.get('elasticsearch', []) %}

instances:
  - name: "elasticsearch"
    dns:
      - "lme-elasticsearch"
      - "localhost"
{% for h in es_hosts %}
      - "{{ h }}"
{% set ah = hostvars[h].get('ansible_host', '') %}
{% if ah and (ah is string) and not (ah is match('^\\d+\\.\\d+\\.\\d+\\.\\d+$')) %}
      - "{{ ah }}"
{% endif %}
{% endfor %}
    ip:
      - "127.0.0.1"
{% for h in es_hosts %}
{% set ip = hostvars[h].get('es_cluster_ip', hostvars[h].get('ansible_host', '')) %}
{% if ip and (ip is string) and (ip is match('^\\d+\\.\\d+\\.\\d+\\.\\d+$')) %}
      - "{{ ip }}"
{% endif %}
{% endfor %}

  - name: "kibana"
    dns:
      - "lme-kibana"
      - "localhost"
    ip:
      - "127.0.0.1"

  - name: "fleet-server"
    dns:
      - "lme-fleet-server"
      - "localhost"
    ip:
      - "127.0.0.1"

  - name: "wazuh-manager"
    dns:
      - "lme-wazuh-manager"
      - "localhost"
    ip:
      - "127.0.0.1"

  - name: "logstash"
    dns:
      - "logstash"
      - "localhost"
    ip:
      - "127.0.0.1"

  - name: "curator"
    dns:
      - "curator"
      - "localhost"
    ip:
      - "127.0.0.1"

  - name: "fleet-distribution"
    dns:
      - "lme-fleet-distribution"
      - "localhost"
    ip:
      - "127.0.0.1"
